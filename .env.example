# ============================================================================
# App Configuration
# ============================================================================

# Base URL for the application (used in emails, redirects, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# Supabase Configuration
# ============================================================================
# IMPORTANT: Use local credentials for development (see README.md)

# For local development (supabase start)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_local_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_local_service_role_key_here

# For production (DO NOT USE THESE IN LOCAL DEVELOPMENT)
# NEXT_PUBLIC_SUPABASE_URL=https://npfouzkvpnyjusdozymu.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_prod_anon_key_here
# SUPABASE_SERVICE_ROLE_KEY=your_prod_service_role_key_here

# ============================================================================
# Email / SMTP Configuration
# ============================================================================

# Development: Uses Inbucket (comes with Supabase local)
SMTP_HOST=127.0.0.1
SMTP_PORT=54325
SMTP_SECURE=false
SMTP_FROM=noreply@themison.com

# Production: Configure your SMTP provider (SendGrid, Resend, etc.)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=true
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key_here
# SMTP_FROM=noreply@themison.com
